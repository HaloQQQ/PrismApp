<Window
    x:Class="MyApp.Prisms.Views.MusicWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:views="clr-namespace:MyApp.Prisms.Views"
    Title="MusicWindow"
    MinWidth="1200"
    MinHeight="640"
    prism:ViewModelLocator.AutoWireViewModel="True"
    MyAttachProperty.CornerRadius="{Binding Settings.CornerRadius}"
    MyAttachProperty.IsMinimalScreen="True"
    Style="{StaticResource Window_WithShadow}">
    <Window.Background>
        <ImageBrush ImageSource="{Binding CurrentBkGrd}" Stretch="UniformToFill" />
    </Window.Background>

    <Grid Background="#33000000">
        <DockPanel>
            <views:WindowTitleBarView DockPanel.Dock="Top" />

            <ContentControl prism:RegionManager.RegionName="MusicPlayerRegion" />
        </DockPanel>

        <views:SwitchBackgroundView HorizontalAlignment="Right" />
    </Grid>
</Window>
